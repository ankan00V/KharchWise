generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int               @id @default(autoincrement())
  name               String
  canonical_name     String
  email              String?           @unique
  password_hash      String?
  created_at         DateTime          @default(now())
  expenses_paid      Expense[]         @relation("PaidBy")
  expense_splits     ExpenseSplit[]
  memberships        GroupMembership[]
  anomalies_resolved ImportAnomaly[]   @relation("ResolvedBy")
  settlements_paid   Settlement[]      @relation("SettlementFrom")
  settlements_rcvd   Settlement[]      @relation("SettlementTo")
}

model Group {
  id          Int               @id @default(autoincrement())
  name        String
  created_at  DateTime          @default(now())
  expenses    Expense[]
  memberships GroupMembership[]
  settlements Settlement[]
}

model GroupMembership {
  id        Int       @id @default(autoincrement())
  group_id  Int
  user_id   Int
  joined_at DateTime
  left_at   DateTime?
  group     Group     @relation(fields: [group_id], references: [id])
  user      User      @relation(fields: [user_id], references: [id])

  @@unique([group_id, user_id])
}

model Expense {
  id                       Int             @id @default(autoincrement())
  group_id                 Int
  description              String
  date                     DateTime
  paid_by_id               Int?
  amount                   Decimal
  currency                 String          @default("INR")
  amount_inr               Decimal
  exchange_rate            Decimal?
  split_type               String
  source_row_number        Int?
  created_at               DateTime        @default(now())
  deleted_at               DateTime?
  superseded_by_anomaly_id Int?
  group                    Group           @relation(fields: [group_id], references: [id])
  paid_by                  User?           @relation("PaidBy", fields: [paid_by_id], references: [id])
  superseded_by_anomaly    ImportAnomaly?  @relation("SupersededExpense", fields: [superseded_by_anomaly_id], references: [id])
  splits                   ExpenseSplit[]
  duplicate_anomalies      ImportAnomaly[] @relation("LinkedDuplicateExpense")
  anomalies                ImportAnomaly[] @relation("LinkedExpense")
}

model ExpenseSplit {
  id               Int      @id @default(autoincrement())
  expense_id       Int
  user_id          Int
  share_amount     Decimal
  share_percentage Decimal?
  share_units      Decimal?
  expense          Expense  @relation(fields: [expense_id], references: [id])
  user             User     @relation(fields: [user_id], references: [id])
}

model Settlement {
  id                Int      @id @default(autoincrement())
  group_id          Int
  from_user_id      Int
  to_user_id        Int
  amount            Decimal
  date              DateTime
  created_at        DateTime @default(now())
  source_row_number Int?
  from_user         User     @relation("SettlementFrom", fields: [from_user_id], references: [id])
  group             Group    @relation(fields: [group_id], references: [id])
  to_user           User     @relation("SettlementTo", fields: [to_user_id], references: [id])
}

model ImportAnomaly {
  id                          Int       @id @default(autoincrement())
  csv_row_number              Int
  anomaly_type                String
  raw_value                   String
  description                 String
  action_taken                String
  status                      String
  resolved_by_id              Int?
  resolved_at                 DateTime?
  linked_expense_id           Int?
  linked_duplicate_expense_id Int?
  superseded_expenses         Expense[] @relation("SupersededExpense")
  linked_duplicate_expense    Expense?  @relation("LinkedDuplicateExpense", fields: [linked_duplicate_expense_id], references: [id])
  linked_expense              Expense?  @relation("LinkedExpense", fields: [linked_expense_id], references: [id])
  resolved_by                 User?     @relation("ResolvedBy", fields: [resolved_by_id], references: [id])
}
